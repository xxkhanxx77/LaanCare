MEDICINE_ALERT_POLL_SECONDS=60
MEDICINE_ALERT_MORNING_MEAL=08:00
MEDICINE_ALERT_NOON_MEAL=12:00
MEDICINE_ALERT_EVENING_MEAL=18:00
MEDICINE_ALERT_BEFORE_MEAL_MINUTES=30
MEDICINE_ALERT_AFTER_MEAL_MINUTES=30
