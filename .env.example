LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token
LINE_CHANNEL_SECRET=your_channel_secret
PORT=5000
PUBLIC_BASE_URL=https://your-public-domain.example
DATABASE_PATH=data/registrations.sqlite3
